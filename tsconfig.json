{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": false,
        "noEmit": true,
        "skipLibCheck": true,
        "allowJs": false
    },
    "include": ["_js/**/*.ts", "_tests/_js/**/*.ts"]
}
